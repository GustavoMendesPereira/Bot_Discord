        "# Script Python para verificar a temperatura de um sistema (simulada)\n",
        "\n",
        "# --- ATENÇÃO ---\n",
        "# Em um cenário real, você precisaria de uma biblioteca ou comando específico do sistema operacional\n",
        "# para obter a temperatura real do sistema (e.g., psutil, ou comandos como 'sensors' no Linux).\n",
        "# Para este exemplo, vamos simular a temperatura.\n",
        "# -----------------\n",
        "\n",
        "# Simula a temperatura atual do sistema (você pode alterar este valor para testar diferentes cenários).\n",
        "temperatura_atual = 35.5 # Exemplo: 35.5 graus Celsius\n",
        "\n",
        "# Define o limite de temperatura. Acima deste valor, um alerta será emitido.\n",
        "limite_temperatura = 30\n",
        "\n",
        "# Exibe a temperatura atual do sistema no console para o usuário.\n",
        "print(\"Temperatura atual do sistema: \" + str(temperatura_atual) + \"°C\")\n",
        "\n",
        "# Verifica se a temperatura atual ultrapassa o limite definido.\n",
        "if temperatura_atual > limite_temperatura:\n",
        "    # Se a temperatura for maior que o limite, exibe uma mensagem de alerta de superaquecimento.\n",
        "    print(\"ALERTA: Superaquecimento detectado! Temperatura acima de 30°C.\")\n",
        "else:\n",
        "    # Caso contrário (se a temperatura estiver dentro ou abaixo do limite), informa que está normal.\n",
        "    print(\"Temperatura do sistema está normal.\")"
      ],
